{
  "name": "blog-backend",
  "version": "2.0.0",
  "description": "Cluster Protocol blog CMS and API (Express + MongoDB)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node backend-js-test/test-all-routes.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop blog-backend",
    "pm2:restart": "pm2 restart blog-backend",
    "pm2:delete": "pm2 delete blog-backend",
    "pm2:logs": "pm2 logs blog-backend",
    "pm2:status": "pm2 status blog-backend"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.12.0"
  }
}
